generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum DeviceStatus {
  ACTIVE
  BLOCKED
}

enum UserCompanyStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  BLOCKED
}

enum ExchangeRateStatus {
  ACTIVE
  ARCHIVED
}

enum InventoryMovementType {
  RECEIPT
  SALE
  ADJUSTMENT
  RETURN
  TRANSFER
  VOID_RESTORE
}

enum InventoryBatchSourceType {
  RECEIPT
  RETURN
  ADJUSTMENT
  VOID_RESTORE
  TRANSFER_IN
}

enum DebtHistoryType {
  sale_credit
  payment
  return
  adjustment
  sale_void
}

enum SaleStatus {
  COMPLETED
  PARTIALLY_RETURNED
  CANCELLED
  RETURNED
}

enum SalePaymentType {
  CASH
  CREDIT
  MIXED
}

enum SaleReturnStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DebtPaymentType {
  PARTIAL
  FULL
}

enum DebtPaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
}

enum OriginalCurrency {
  UZS
  USD
}

enum SupplierStatus {
  ACTIVE
  ARCHIVED
}

enum SupplierReceivePaymentType {
  CASH
  CREDIT
}

enum SupplierDebtHistoryType {
  receipt_credit
  payment
  adjustment
}

enum SupplierPaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
}

enum ReportPeriod {
  daily
  weekly
  monthly
  yearly
  custom
}

enum ReportExportFormat {
  PDF
  XLSX
  CSV
}

enum ReportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ExpenseCategory {
  RENT
  SALARY
  UTILITIES
  SUPPLIES
  MARKETING
  TRANSPORT
  MAINTENANCE
  OTHER
}

enum NotificationSeverity {
  info
  warning
  success
  error
}

enum NotificationCategory {
  STOCK_ALERT
  DEBT_ALERT
  SUPPLIER_DEBT
  CUSTOMER_DEBT
  LOW_STOCK
  EXPIRED_PRODUCT
  SYSTEM
  LOGIN
}

enum BackupType {
  FULL
  INCREMENTAL
}

enum BackupJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum BackupTrigger {
  MANUAL
  AUTOMATIC
}

model Company {
  id        String        @id @default(uuid()) @db.Uuid
  name      String        @db.VarChar(255)
  code      String        @unique @db.VarChar(50)
  status    CompanyStatus @default(ACTIVE)
  settings  Json          @default("{}")
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?     @map("deleted_at") @db.Timestamptz(6)

  branches       Branch[]
  companyModules CompanyModule[]
  roles          Role[]
  userCompanies  UserCompany[]
  sessions       Session[]
  auditLogs      AuditLog[]
  productCategories ProductCategory[]
  products       Product[]
  customers      Customer[]
  debtHistory    DebtHistory[]
  exchangeRates  ExchangeRate[]
  warehouses     Warehouse[]
  inventoryBatches InventoryBatch[]
  inventoryMovements InventoryMovement[]
  sales            Sale[]
  saleReturns      SaleReturn[]
  saleFifoAllocations SaleFifoAllocation[]
  debtPayments     DebtPayment[]
  idempotencyKeys  IdempotencyKey[]
  saleNumberSequences SaleNumberSequence[]
  suppliers        Supplier[]
  supplierReceipts SupplierReceipt[]
  supplierPayments SupplierPayment[]
  supplierDebtHistory SupplierDebtHistory[]
  expenses         Expense[]
  reportJobs       ReportJob[]
  notifications    Notification[]
  backupJobs       BackupJob[]

  @@map("companies")
}

model Branch {
  id        String        @id @default(uuid()) @db.Uuid
  companyId String        @map("company_id") @db.Uuid
  name      String        @db.VarChar(255)
  address   String?       @db.Text
  isDefault Boolean       @default(false) @map("is_default")
  status    CompanyStatus @default(ACTIVE)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  company       Company        @relation(fields: [companyId], references: [id])
  userCompanies UserCompany[]
  warehouses    Warehouse[]
  sales         Sale[]
  expenses      Expense[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("branches")
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique @db.VarChar(255)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  firstName    String     @map("first_name") @db.VarChar(100)
  lastName     String     @map("last_name") @db.VarChar(100)
  status       UserStatus @default(ACTIVE)
  blockedAt    DateTime?  @map("blocked_at") @db.Timestamptz(6)
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  devices       Device[]
  sessions      Session[]
  userCompanies UserCompany[]
  auditLogs     AuditLog[]
  exchangeRates ExchangeRate[]
  inventoryMovements InventoryMovement[]
  debtHistory   DebtHistory[]
  sales         Sale[]        @relation("SaleCashier")
  voidedSales   Sale[]        @relation("SaleVoidedBy")
  saleReturnsCreated SaleReturn[] @relation("ReturnCreatedBy")
  saleReturnsApproved SaleReturn[] @relation("ReturnApprovedBy")
  saleReturnsRejected SaleReturn[] @relation("ReturnRejectedBy")
  debtPaymentsReceived DebtPayment[] @relation("DebtPaymentReceiver")
  supplierPaymentsRecorded SupplierPayment[] @relation("SupplierPaymentRecorder")
  expensesRecorded         Expense[]           @relation("ExpenseRecorder")
  reportJobs               ReportJob[]
  notifications            Notification[]
  backupJobs               BackupJob[]

  @@map("users")
}

model Device {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  deviceUuid String       @map("device_uuid") @db.Uuid
  name       String       @db.VarChar(255)
  platform   String       @db.VarChar(50)
  osVersion  String?      @map("os_version") @db.VarChar(50)
  ipAddress  String?      @map("ip_address")
  status     DeviceStatus @default(ACTIVE)
  lastSeenAt DateTime?    @map("last_seen_at") @db.Timestamptz(6)
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  user     User      @relation(fields: [userId], references: [id])
  sessions Session[]

  @@unique([userId, deviceUuid])
  @@index([userId])
  @@map("devices")
}

model Session {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  deviceId          String    @map("device_id") @db.Uuid
  companyId         String?   @map("company_id") @db.Uuid
  refreshTokenHash  String    @map("refresh_token_hash") @db.VarChar(255)
  ipAddress         String?   @map("ip_address")
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user    User     @relation(fields: [userId], references: [id])
  device  Device   @relation(fields: [deviceId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])

  @@index([userId, revokedAt])
  @@map("sessions")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String?  @map("company_id") @db.Uuid
  name        String   @db.VarChar(100)
  description String?  @db.Text
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  company         Company?         @relation(fields: [companyId], references: [id])
  rolePermissions RolePermission[]
  userCompanies   UserCompany[]

  @@map("roles")
}

model Permission {
  id          String @id @default(uuid()) @db.Uuid
  code        String @unique @db.VarChar(100)
  module      String @db.VarChar(50)
  description String @db.Text

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserCompany {
  id        String            @id @default(uuid()) @db.Uuid
  userId    String            @map("user_id") @db.Uuid
  companyId String            @map("company_id") @db.Uuid
  roleId    String            @map("role_id") @db.Uuid
  branchId  String?           @map("branch_id") @db.Uuid
  status    UserCompanyStatus @default(ACTIVE)
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])
  role    Role    @relation(fields: [roleId], references: [id])
  branch  Branch? @relation(fields: [branchId], references: [id])

  @@unique([userId, companyId])
  @@index([companyId])
  @@map("user_companies")
}

model Module {
  id     String  @id @default(uuid()) @db.Uuid
  code   String  @unique @db.VarChar(50)
  name   String  @db.VarChar(100)
  isCore Boolean @default(false) @map("is_core")

  companyModules CompanyModule[]

  @@map("modules")
}

model CompanyModule {
  companyId String  @map("company_id") @db.Uuid
  moduleId  String  @map("module_id") @db.Uuid
  enabled   Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id])
  module  Module  @relation(fields: [moduleId], references: [id])

  @@id([companyId, moduleId])
  @@map("company_modules")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  companyId  String?  @map("company_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(50)
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.Uuid
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address")
  requestId  String?  @map("request_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  company Company? @relation(fields: [companyId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model ProductCategory {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  name      String    @db.VarChar(255)
  parentId  String?   @map("parent_id") @db.Uuid
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  company  Company           @relation(fields: [companyId], references: [id])
  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[]   @relation("CategoryHierarchy")
  products Product[]

  @@unique([companyId, name, parentId])
  @@index([companyId])
  @@map("product_categories")
}

model Product {
  id            String        @id @default(uuid()) @db.Uuid
  companyId     String        @map("company_id") @db.Uuid
  sku           String        @db.VarChar(100)
  barcode       String?       @db.VarChar(100)
  name          String        @db.VarChar(500)
  categoryId    String?       @map("category_id") @db.Uuid
  unitOfMeasure String        @default("pcs") @map("unit_of_measure") @db.VarChar(20)
  unitsPerBox   Int           @default(1) @map("units_per_box")
  minStockLevel Decimal       @default(0) @map("min_stock_level") @db.Decimal(18, 4)
  status        ProductStatus @default(ACTIVE)
  expiresAt     DateTime?     @map("expires_at") @db.Date
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?     @map("deleted_at") @db.Timestamptz(6)

  company          Company           @relation(fields: [companyId], references: [id])
  category         ProductCategory?  @relation(fields: [categoryId], references: [id])
  prices           ProductPrice?
  inventoryBatches InventoryBatch[]
  inventoryMovements InventoryMovement[]
  saleItems        SaleItem[]
  saleFifoAllocations SaleFifoAllocation[]
  saleReturnItems  SaleReturnItem[]
  supplierReceipts SupplierReceipt[]

  @@unique([companyId, sku])
  @@unique([companyId, barcode])
  @@index([companyId])
  @@index([categoryId])
  @@map("products")
}

model ProductPrice {
  productId          String   @id @map("product_id") @db.Uuid
  purchasePriceUzs   Decimal  @default(0) @map("purchase_price_uzs") @db.Decimal(18, 4)
  purchasePriceUsd   Decimal  @default(0) @map("purchase_price_usd") @db.Decimal(18, 4)
  salePriceUzs       Decimal  @default(0) @map("sale_price_uzs") @db.Decimal(18, 4)
  salePriceUsd       Decimal  @default(0) @map("sale_price_usd") @db.Decimal(18, 4)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_prices")
}

model Customer {
  id                   String         @id @default(uuid()) @db.Uuid
  companyId            String         @map("company_id") @db.Uuid
  name                 String         @db.VarChar(255)
  phone                String         @db.VarChar(20)
  phoneSecondary       String?        @map("phone_secondary") @db.VarChar(20)
  email                String?        @db.VarChar(255)
  address              String?        @db.Text
  partnershipStartDate DateTime?      @map("partnership_start_date") @db.Date
  notes                String?        @db.Text
  status               CustomerStatus @default(ACTIVE)
  totalDebtUzs         Decimal        @default(0) @map("total_debt_uzs") @db.Decimal(18, 4)
  totalDebtUsd         Decimal        @default(0) @map("total_debt_usd") @db.Decimal(18, 4)
  totalPurchasesUzs    Decimal        @default(0) @map("total_purchases_uzs") @db.Decimal(18, 4)
  lastPurchaseAt       DateTime?      @map("last_purchase_at") @db.Timestamptz(6)
  lastPaymentAt        DateTime?      @map("last_payment_at") @db.Timestamptz(6)
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?      @map("deleted_at") @db.Timestamptz(6)

  company     Company       @relation(fields: [companyId], references: [id])
  debtHistory DebtHistory[]
  sales       Sale[]
  debtPayments DebtPayment[]
  saleReturns SaleReturn[]

  @@index([companyId])
  @@index([companyId, name])
  @@map("customers")
}

model DebtHistory {
  id              String          @id @default(uuid()) @db.Uuid
  companyId       String          @map("company_id") @db.Uuid
  customerId      String          @map("customer_id") @db.Uuid
  type            DebtHistoryType
  amountUzs       Decimal         @default(0) @map("amount_uzs") @db.Decimal(18, 4)
  amountUsd       Decimal         @default(0) @map("amount_usd") @db.Decimal(18, 4)
  balanceAfterUzs Decimal         @map("balance_after_uzs") @db.Decimal(18, 4)
  balanceAfterUsd Decimal         @map("balance_after_usd") @db.Decimal(18, 4)
  referenceType   String?         @map("reference_type") @db.VarChar(30)
  referenceId     String?         @map("reference_id") @db.Uuid
  referenceLabel  String?         @map("reference_label") @db.VarChar(100)
  recordedBy      String          @map("recorded_by") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  company  Company  @relation(fields: [companyId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  recorder User     @relation(fields: [recordedBy], references: [id])

  @@index([companyId, customerId, createdAt(sort: Desc)])
  @@map("debt_history")
}

model ExchangeRate {
  id            String             @id @default(uuid()) @db.Uuid
  companyId     String             @map("company_id") @db.Uuid
  rate          Decimal            @db.Decimal(18, 4)
  effectiveFrom DateTime           @default(now()) @map("effective_from") @db.Timestamptz(6)
  status        ExchangeRateStatus @default(ACTIVE)
  notes         String?            @db.Text
  setBy         String             @map("set_by") @db.Uuid
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id])
  setter  User    @relation(fields: [setBy], references: [id])

  @@index([companyId, status])
  @@index([companyId, effectiveFrom(sort: Desc)])
  @@map("exchange_rates")
}

model Warehouse {
  id        String        @id @default(uuid()) @db.Uuid
  companyId String        @map("company_id") @db.Uuid
  branchId  String        @map("branch_id") @db.Uuid
  name      String        @db.VarChar(255)
  address   String?       @db.Text
  isDefault Boolean       @default(false) @map("is_default")
  status    CompanyStatus @default(ACTIVE)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  company            Company             @relation(fields: [companyId], references: [id])
  branch             Branch              @relation(fields: [branchId], references: [id])
  inventoryBatches   InventoryBatch[]
  inventoryMovements InventoryMovement[]
  supplierReceipts   SupplierReceipt[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("warehouses")
}

model InventoryBatch {
  id           String                  @id @default(uuid()) @db.Uuid
  companyId    String                  @map("company_id") @db.Uuid
  productId    String                  @map("product_id") @db.Uuid
  warehouseId  String                  @map("warehouse_id") @db.Uuid
  quantity     Decimal                 @db.Decimal(18, 4)
  remainingQty Decimal                 @map("remaining_qty") @db.Decimal(18, 4)
  unitCostUzs  Decimal                 @map("unit_cost_uzs") @db.Decimal(18, 4)
  unitCostUsd  Decimal                 @map("unit_cost_usd") @db.Decimal(18, 4)
  receivedAt   DateTime                @map("received_at") @db.Timestamptz(6)
  sourceType   InventoryBatchSourceType @default(RECEIPT) @map("source_type")
  sourceId     String?                 @map("source_id") @db.Uuid
  createdAt    DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)

  company   Company             @relation(fields: [companyId], references: [id])
  product   Product             @relation(fields: [productId], references: [id])
  warehouse Warehouse           @relation(fields: [warehouseId], references: [id])
  movements InventoryMovement[]
  fifoAllocations SaleFifoAllocation[]
  supplierReceipts SupplierReceipt[]

  @@index([companyId, productId, warehouseId])
  @@index([companyId, productId, receivedAt])
  @@map("inventory_batches")
}

model InventoryMovement {
  id            String                @id @default(uuid()) @db.Uuid
  companyId     String                @map("company_id") @db.Uuid
  productId     String                @map("product_id") @db.Uuid
  warehouseId   String                @map("warehouse_id") @db.Uuid
  batchId       String?               @map("batch_id") @db.Uuid
  type          InventoryMovementType
  quantity      Decimal               @db.Decimal(18, 4)
  referenceType String?               @map("reference_type") @db.VarChar(30)
  referenceId   String?               @map("reference_id") @db.Uuid
  note          String?               @db.Text
  performedBy   String                @map("performed_by") @db.Uuid
  createdAt     DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  company   Company         @relation(fields: [companyId], references: [id])
  product   Product         @relation(fields: [productId], references: [id])
  warehouse Warehouse       @relation(fields: [warehouseId], references: [id])
  batch     InventoryBatch? @relation(fields: [batchId], references: [id])
  performer User            @relation(fields: [performedBy], references: [id])

  @@index([companyId, productId, createdAt(sort: Desc)])
  @@index([companyId, warehouseId, createdAt(sort: Desc)])
  @@map("inventory_movements")
}

model SaleNumberSequence {
  companyId  String @map("company_id") @db.Uuid
  year       Int
  lastValue  Int    @default(0) @map("last_value")

  company Company @relation(fields: [companyId], references: [id])

  @@id([companyId, year])
  @@map("sale_number_sequences")
}

model Sale {
  id               String           @id @default(uuid()) @db.Uuid
  companyId        String           @map("company_id") @db.Uuid
  branchId         String           @map("branch_id") @db.Uuid
  saleNumber       String           @map("sale_number") @db.VarChar(30)
  customerId       String?          @map("customer_id") @db.Uuid
  cashierId        String           @map("cashier_id") @db.Uuid
  originalCurrency OriginalCurrency @map("original_currency")
  exchangeRateUsed Decimal          @map("exchange_rate_used") @db.Decimal(18, 4)
  subtotalUzs      Decimal          @default(0) @map("subtotal_uzs") @db.Decimal(18, 4)
  subtotalUsd      Decimal          @default(0) @map("subtotal_usd") @db.Decimal(18, 4)
  discountUzs      Decimal          @default(0) @map("discount_uzs") @db.Decimal(18, 4)
  discountUsd      Decimal          @default(0) @map("discount_usd") @db.Decimal(18, 4)
  totalUzs         Decimal          @default(0) @map("total_uzs") @db.Decimal(18, 4)
  totalUsd         Decimal          @default(0) @map("total_usd") @db.Decimal(18, 4)
  paymentType      SalePaymentType  @map("payment_type")
  amountPaidUzs    Decimal          @default(0) @map("amount_paid_uzs") @db.Decimal(18, 4)
  amountPaidUsd    Decimal          @default(0) @map("amount_paid_usd") @db.Decimal(18, 4)
  status           SaleStatus       @default(COMPLETED)
  notes            String?          @db.Text
  voidedAt         DateTime?        @map("voided_at") @db.Timestamptz(6)
  voidedBy         String?          @map("voided_by") @db.Uuid
  completedAt      DateTime         @default(now()) @map("completed_at") @db.Timestamptz(6)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  company         Company              @relation(fields: [companyId], references: [id])
  branch          Branch               @relation(fields: [branchId], references: [id])
  customer        Customer?            @relation(fields: [customerId], references: [id])
  cashier         User                 @relation("SaleCashier", fields: [cashierId], references: [id])
  voidedByUser    User?                @relation("SaleVoidedBy", fields: [voidedBy], references: [id])
  items           SaleItem[]
  fifoAllocations SaleFifoAllocation[]
  returns         SaleReturn[]

  @@unique([companyId, saleNumber])
  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, customerId, createdAt(sort: Desc)])
  @@map("sales")
}

model SaleItem {
  id           String  @id @default(uuid()) @db.Uuid
  saleId       String  @map("sale_id") @db.Uuid
  productId    String  @map("product_id") @db.Uuid
  quantity     Decimal @db.Decimal(18, 4)
  unitPriceUzs Decimal @map("unit_price_uzs") @db.Decimal(18, 4)
  unitPriceUsd Decimal @map("unit_price_usd") @db.Decimal(18, 4)
  totalUzs     Decimal @map("total_uzs") @db.Decimal(18, 4)
  totalUsd     Decimal @map("total_usd") @db.Decimal(18, 4)
  cogsUzs      Decimal @default(0) @map("cogs_uzs") @db.Decimal(18, 4)
  cogsUsd      Decimal @default(0) @map("cogs_usd") @db.Decimal(18, 4)

  sale            Sale                 @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product         Product              @relation(fields: [productId], references: [id])
  fifoAllocations SaleFifoAllocation[]

  @@index([saleId])
  @@map("sale_items")
}

model SaleFifoAllocation {
  id          String  @id @default(uuid()) @db.Uuid
  companyId   String  @map("company_id") @db.Uuid
  saleId      String  @map("sale_id") @db.Uuid
  saleItemId  String  @map("sale_item_id") @db.Uuid
  batchId     String  @map("batch_id") @db.Uuid
  productId   String  @map("product_id") @db.Uuid
  quantity    Decimal @db.Decimal(18, 4)
  unitCostUzs Decimal @map("unit_cost_uzs") @db.Decimal(18, 4)
  unitCostUsd Decimal @map("unit_cost_usd") @db.Decimal(18, 4)
  costUzs     Decimal @map("cost_uzs") @db.Decimal(18, 4)
  costUsd     Decimal @map("cost_usd") @db.Decimal(18, 4)

  company  Company        @relation(fields: [companyId], references: [id])
  sale     Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleItem SaleItem       @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  batch    InventoryBatch @relation(fields: [batchId], references: [id])
  product  Product        @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@map("sale_fifo_allocations")
}

model SaleReturn {
  id               String           @id @default(uuid()) @db.Uuid
  companyId        String           @map("company_id") @db.Uuid
  saleId           String           @map("sale_id") @db.Uuid
  customerId       String?          @map("customer_id") @db.Uuid
  exchangeRateUsed Decimal          @map("exchange_rate_used") @db.Decimal(18, 4)
  amountUzs        Decimal          @map("amount_uzs") @db.Decimal(18, 4)
  amountUsd        Decimal          @map("amount_usd") @db.Decimal(18, 4)
  reason           String           @db.Text
  status           SaleReturnStatus @default(PENDING)
  approvedBy       String?          @map("approved_by") @db.Uuid
  rejectedBy       String?          @map("rejected_by") @db.Uuid
  decisionNote     String?          @map("decision_note") @db.Text
  createdBy        String           @map("created_by") @db.Uuid
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  decidedAt        DateTime?        @map("decided_at") @db.Timestamptz(6)

  company        Company           @relation(fields: [companyId], references: [id])
  sale           Sale              @relation(fields: [saleId], references: [id])
  customer       Customer?         @relation(fields: [customerId], references: [id])
  creator        User              @relation("ReturnCreatedBy", fields: [createdBy], references: [id])
  approver       User?             @relation("ReturnApprovedBy", fields: [approvedBy], references: [id])
  rejecter       User?             @relation("ReturnRejectedBy", fields: [rejectedBy], references: [id])
  items          SaleReturnItem[]

  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, saleId])
  @@map("sale_returns")
}

model SaleReturnItem {
  id        String  @id @default(uuid()) @db.Uuid
  returnId  String  @map("return_id") @db.Uuid
  productId String  @map("product_id") @db.Uuid
  quantity  Decimal @db.Decimal(18, 4)
  amountUzs Decimal @map("amount_uzs") @db.Decimal(18, 4)

  saleReturn SaleReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@index([returnId])
  @@map("sale_return_items")
}

model DebtPayment {
  id               String             @id @default(uuid()) @db.Uuid
  companyId        String             @map("company_id") @db.Uuid
  customerId       String             @map("customer_id") @db.Uuid
  amount           Decimal            @db.Decimal(18, 4)
  currency         OriginalCurrency
  amountUzs        Decimal            @map("amount_uzs") @db.Decimal(18, 4)
  amountUsd        Decimal            @map("amount_usd") @db.Decimal(18, 4)
  exchangeRateUsed Decimal            @map("exchange_rate_used") @db.Decimal(18, 4)
  paymentType      DebtPaymentType    @map("payment_type")
  paymentMethod    DebtPaymentMethod  @map("payment_method")
  notes            String?            @db.Text
  reversedAt       DateTime?          @map("reversed_at") @db.Timestamptz(6)
  reversalReason   String?            @map("reversal_reason") @db.Text
  receivedBy       String             @map("received_by") @db.Uuid
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  company  Company  @relation(fields: [companyId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  receiver User     @relation("DebtPaymentReceiver", fields: [receivedBy], references: [id])

  @@index([companyId, customerId, createdAt(sort: Desc)])
  @@map("debt_payments")
}

model IdempotencyKey {
  id             String   @id @default(uuid()) @db.Uuid
  companyId      String   @map("company_id") @db.Uuid
  idempotencyKey String   @map("idempotency_key") @db.VarChar(255)
  endpoint       String   @db.VarChar(100)
  requestHash    String?  @map("request_hash") @db.VarChar(64)
  responseStatus Int      @map("response_status")
  responseBody   Json     @map("response_body")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt      DateTime @map("expires_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, idempotencyKey, endpoint])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

model Supplier {
  id            String         @id @default(uuid()) @db.Uuid
  companyId     String         @map("company_id") @db.Uuid
  name          String         @db.VarChar(255)
  phone         String         @db.VarChar(20)
  contactPerson String?        @map("contact_person") @db.VarChar(255)
  notes         String?        @db.Text
  status        SupplierStatus @default(ACTIVE)
  totalDebtUzs  Decimal        @default(0) @map("total_debt_uzs") @db.Decimal(18, 4)
  totalPaidUzs  Decimal        @default(0) @map("total_paid_uzs") @db.Decimal(18, 4)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?      @map("deleted_at") @db.Timestamptz(6)

  company     Company               @relation(fields: [companyId], references: [id])
  receipts    SupplierReceipt[]
  payments    SupplierPayment[]
  debtHistory SupplierDebtHistory[]

  @@index([companyId])
  @@map("suppliers")
}

model SupplierReceipt {
  id               String                     @id @default(uuid()) @db.Uuid
  companyId        String                     @map("company_id") @db.Uuid
  supplierId       String                     @map("supplier_id") @db.Uuid
  productId        String                     @map("product_id") @db.Uuid
  warehouseId      String                     @map("warehouse_id") @db.Uuid
  inventoryBatchId String?                    @map("inventory_batch_id") @db.Uuid
  quantity         Decimal                    @db.Decimal(18, 4)
  unitCostUzs      Decimal                    @map("unit_cost_uzs") @db.Decimal(18, 4)
  totalCostUzs     Decimal                    @map("total_cost_uzs") @db.Decimal(18, 4)
  paymentType      SupplierReceivePaymentType @map("payment_type")
  note             String?                    @db.Text
  receivedBy       String                     @map("received_by") @db.Uuid
  createdAt        DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)

  company   Company          @relation(fields: [companyId], references: [id])
  supplier  Supplier         @relation(fields: [supplierId], references: [id])
  product   Product          @relation(fields: [productId], references: [id])
  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  batch     InventoryBatch?  @relation(fields: [inventoryBatchId], references: [id])

  @@index([companyId, supplierId, createdAt(sort: Desc)])
  @@map("supplier_receipts")
}

model SupplierPayment {
  id            String                @id @default(uuid()) @db.Uuid
  companyId     String                @map("company_id") @db.Uuid
  supplierId    String                @map("supplier_id") @db.Uuid
  amountUzs     Decimal               @map("amount_uzs") @db.Decimal(18, 4)
  paymentMethod SupplierPaymentMethod @map("payment_method")
  notes         String?               @db.Text
  recordedBy    String                @map("recorded_by") @db.Uuid
  createdAt     DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  company  Company  @relation(fields: [companyId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
  recorder User     @relation("SupplierPaymentRecorder", fields: [recordedBy], references: [id])

  @@index([companyId, supplierId, createdAt(sort: Desc)])
  @@map("supplier_payments")
}

model SupplierDebtHistory {
  id              String                  @id @default(uuid()) @db.Uuid
  companyId       String                  @map("company_id") @db.Uuid
  supplierId      String                  @map("supplier_id") @db.Uuid
  type            SupplierDebtHistoryType
  amountUzs       Decimal                 @map("amount_uzs") @db.Decimal(18, 4)
  balanceAfterUzs Decimal                 @map("balance_after_uzs") @db.Decimal(18, 4)
  reference       String?                 @db.VarChar(255)
  createdAt       DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  recordedBy      String                  @map("recorded_by") @db.Uuid

  company  Company  @relation(fields: [companyId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([companyId, supplierId, createdAt(sort: Desc)])
  @@map("supplier_debt_history")
}

model Expense {
  id          String          @id @default(uuid()) @db.Uuid
  companyId   String          @map("company_id") @db.Uuid
  branchId    String?         @map("branch_id") @db.Uuid
  category    ExpenseCategory
  description String          @db.VarChar(500)
  amountUzs   Decimal         @map("amount_uzs") @db.Decimal(18, 4)
  amountUsd   Decimal         @default(0) @map("amount_usd") @db.Decimal(18, 4)
  expenseDate DateTime        @map("expense_date") @db.Date
  recordedBy  String          @map("recorded_by") @db.Uuid
  notes       String?         @db.Text
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?       @map("deleted_at") @db.Timestamptz(6)

  company  Company @relation(fields: [companyId], references: [id])
  branch   Branch? @relation(fields: [branchId], references: [id])
  recorder User    @relation("ExpenseRecorder", fields: [recordedBy], references: [id])

  @@index([companyId, expenseDate(sort: Desc)])
  @@index([companyId, category, expenseDate(sort: Desc)])
  @@index([companyId, branchId, expenseDate(sort: Desc)])
  @@map("expenses")
}

model ReportJob {
  id           String             @id @default(uuid()) @db.Uuid
  companyId    String             @map("company_id") @db.Uuid
  userId       String             @map("user_id") @db.Uuid
  template     String             @db.VarChar(100)
  category     String             @db.VarChar(50)
  format       ReportExportFormat
  status       ReportJobStatus    @default(PENDING)
  period       ReportPeriod?
  dateFrom     DateTime?          @map("date_from") @db.Date
  dateTo       DateTime?          @map("date_to") @db.Date
  parameters   Json               @default("{}")
  rowCount     Int?               @map("row_count")
  filePath     String?            @map("file_path") @db.VarChar(500)
  fileName     String?            @map("file_name") @db.VarChar(255)
  mimeType     String?            @map("mime_type") @db.VarChar(100)
  fileSize     Int?               @map("file_size")
  errorMessage String?            @map("error_message") @db.Text
  progress     Int                @default(0)
  expiresAt    DateTime?          @map("expires_at") @db.Timestamptz(6)
  completedAt  DateTime?          @map("completed_at") @db.Timestamptz(6)
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([companyId, userId, createdAt(sort: Desc)])
  @@index([companyId, status, createdAt(sort: Desc)])
  @@index([companyId, template, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("report_jobs")
}

model Notification {
  id         String               @id @default(uuid()) @db.Uuid
  companyId  String               @map("company_id") @db.Uuid
  userId     String?              @map("user_id") @db.Uuid
  title      String               @db.VarChar(255)
  body       String               @db.Text
  severity   NotificationSeverity @default(info)
  category   NotificationCategory
  read       Boolean              @default(false)
  readAt     DateTime?            @map("read_at") @db.Timestamptz(6)
  entityType String?              @map("entity_type") @db.VarChar(50)
  entityId   String?              @map("entity_id") @db.Uuid
  metadata   Json                 @default("{}")
  deletedAt  DateTime?            @map("deleted_at") @db.Timestamptz(6)
  createdAt  DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([companyId, userId, read, createdAt(sort: Desc)])
  @@index([companyId, category, entityId, createdAt(sort: Desc)])
  @@index([companyId, deletedAt])
  @@map("notifications")
}

model BackupJob {
  id           String          @id @default(uuid()) @db.Uuid
  companyId    String          @map("company_id") @db.Uuid
  userId       String?         @map("user_id") @db.Uuid
  type         BackupType
  trigger      BackupTrigger   @default(MANUAL)
  status       BackupJobStatus @default(PENDING)
  filePath     String?         @map("file_path") @db.VarChar(500)
  fileName     String?         @map("file_name") @db.VarChar(255)
  mimeType     String?         @map("mime_type") @db.VarChar(100)
  fileSize     Int?            @map("file_size")
  errorMessage String?         @map("error_message") @db.Text
  metadata     Json            @default("{}")
  completedAt  DateTime?       @map("completed_at") @db.Timestamptz(6)
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([companyId, status, createdAt(sort: Desc)])
  @@index([companyId, createdAt(sort: Desc)])
  @@map("backup_jobs")
}
